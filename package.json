{
  "name": "temporals",
  "version": "0.0.2",
  "description": "Lazy sequences, ranges, intervals, and RRULE recurrence built on the TC39 Temporal API.",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cron": {
      "import": {
        "types": "./dist/cron.d.ts",
        "default": "./dist/cron.js"
      },
      "require": {
        "types": "./dist/cron.d.cts",
        "default": "./dist/cron.cjs"
      }
    },
    "./business": {
      "import": {
        "types": "./dist/business.d.ts",
        "default": "./dist/business.js"
      },
      "require": {
        "types": "./dist/business.d.cts",
        "default": "./dist/business.cjs"
      }
    },
    "./humanize": {
      "import": {
        "types": "./dist/humanize.d.ts",
        "default": "./dist/humanize.js"
      },
      "require": {
        "types": "./dist/humanize.d.cts",
        "default": "./dist/humanize.cjs"
      }
    },
    "./ics": {
      "import": {
        "types": "./dist/ics.d.ts",
        "default": "./dist/ics.js"
      },
      "require": {
        "types": "./dist/ics.d.cts",
        "default": "./dist/ics.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "node --import tsx --test test/*.test.ts",
    "test:example": "node --test examples/scheduler",
    "coverage": "node --import tsx --test --experimental-test-coverage test/*.test.ts",
    "example": "node examples/scheduler/demo.mjs",
    "examples": "for f in examples/*.mjs; do echo \"# $f\"; node \"$f\" >/dev/null || exit 1; done",
    "docs": "typedoc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "temporal",
    "date",
    "datetime",
    "range",
    "date-range",
    "interval",
    "recurrence",
    "rrule",
    "iterator",
    "sequence"
  ],
  "author": "John Henry <john@iamjohnhenry.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnhenry/temporals.git"
  },
  "homepage": "https://github.com/johnhenry/temporals#readme",
  "bugs": {
    "url": "https://github.com/johnhenry/temporals/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "temporal-polyfill": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "temporal-polyfill": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "temporal-polyfill": "^1.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  }
}
